%h3.text-center Daily Vocabulary
%p.text-center.mb-4 Login
-# = devise_error_messages! 

= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f|
  -# = bootstrap_devise_error_messages!
  = f.email_field :email, autofocus: true, autocomplete: 'email', placeholder: 'Email', class: 'mb-3 form-control'
  = f.password_field :password, placeholder: 'Password', class: 'mb-3 form-control'
  .mb-1
    Don't have an account yet? 
    = link_to('Create account', new_user_registration_path)
  .mb-4
    Forgot your password? 
    = link_to('Reset password', new_user_password_path)    
  = f.submit  'Login', class: 'btn btn-sm btn-dark btn-block'

